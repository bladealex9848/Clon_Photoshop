# ---------------------------------------------------------------------------
# Clon_Photoshop / PhotoClone AI — variables de entorno (NO commitear .env*)
# En el VPS los secretos viven en /root/.clon_photoshop_env (chmod 600),
# cargado por el drop-in de systemd. Este archivo es sólo referencia.
# ---------------------------------------------------------------------------

# --- Persistencia (MariaDB local) ---
CLON_PS_DB_HOST=127.0.0.1
CLON_PS_DB_PORT=3306
CLON_PS_DB_USER=clon_photoshop
CLON_PS_DB_PASSWORD=changeme
CLON_PS_DB_NAME=clon_photoshop
CLON_PS_DB_SOCKET=/run/mysqld/mysqld.sock

# --- Admin sembrado al iniciar (idempotente; sólo se crea si no existe) ---
CLON_PS_ADMIN_EMAIL=bladealex@gmail.com
CLON_PS_ADMIN_PASSWORD=          # aleatoria, sólo en el env del servidor
CLON_PS_SESSION_SECRET=
CLON_PS_BASE_URL=https://photoshop.cedula360.tech

# --- Alianza "Login con Cédula 360" (server-to-server) ---
# IMPORTANTE: backend REAL de Cédula 360. NUNCA :9091 (stub sin auth).
CEDULA360_API_BASE=http://localhost:3081
CEDULA360_INTERNAL_TOKEN=        # opcional: bypass rate-limit (x-internal-cron-token)

# --- reCAPTCHA v3 (claves Cédula 360, fail-open, umbral 0.3) ---
RECAPTCHA_SITE_KEY=6Ldufr4sAAAAAEX6uLIrV3Uk4auM7zksyUvdeA-k
RECAPTCHA_SECRET_KEY=            # sólo en el servidor
RECAPTCHA_MIN_SCORE=0.3
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=6Ldufr4sAAAAAEX6uLIrV3Uk4auM7zksyUvdeA-k

# --- IA del editor (opcional, separación de capas) ---
REPLICATE_API_TOKEN=r8_your_token_here
